{
	// Place your snippets for python here. Each snippet is defined under a snippet name and has a prefix, body and 
	// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:
	// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the 
	// same ids are connected.
	// Example:
	// "Print to console": {
	// 	"prefix": "log",
	// 	"body": [
	// 		"console.log('$1');",
	// 		"$2"
	// 	],
	// 	"description": "Log output to console"
	// }

	// Function snippets
	"if __name__ == '__main__'": {
		"prefix": "if __name__ == '__main__'",
		"body": [
			"def main():",
			"\t${1:pass}",
			"",
			"if __name__ == '__main__':",
			"\tmain()",
		],
		"description": "__main__ function"
	},
	"def function": {
		"prefix": "def",
		"body": [
			"def ${1:function}(${2:}) -> ${3:None}:",
			"\t${4:raise NotImplementedError}",
		],
		"description": "Generate template function"
	},

	// Try Catch and Exceptions snippets
	"try, except ValueError": {
		"prefix": "try & except ValueError",
		"body": [
			"try:",
			"\tpass",
			"except ${1:ValueError}:",
			"\tpass",
		],
		"description": "Generate try except"
	},
	"try, except as Exception": {
		"prefix": "try & except as Exception",
		"body": [
			"try:",
			"\tpass",
			"except Exception as e:",
			"\tprint(${1:e})",
		],
		"description": "Generate try except Exception"
	},

	// 
	// Django snippets
	// 
	"max_length Django | johanfire": {
		"prefix": "max_length",
		"body": [
			"max_length=${1:100}${2}",
		],
		"description": "'max_length' parameter for models in Django"
	},
	"unique Django | johanfire": {
		"prefix": "unique",
		"body": [
			"unique=${1:True}${2}",
		],
		"description": "'unique' parameter for models in Django"
	},
	"blank Django | johanfire": {
		"prefix": "blank",
		"body": [
			"blank=${1:False}${2}",
		],
		"description": "'blank' parameter for models in Django"
	},
	"upload_to Django | johanfire": {
		"prefix": "upload_to",
		"body": [
			"upload_to='${1}'${2}",
		],
		"description": "'upload_to' parameter for models in Django"
	},
}