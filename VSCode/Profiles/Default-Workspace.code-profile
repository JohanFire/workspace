{"name":"Default-Workspace","settings":"{\"settings\":\"{\\r\\n    \\\"python.autoComplete.addBrackets\\\": true,\\r\\n    \\\"explorer.confirmDragAndDrop\\\": false,\\r\\n    \\\"python.analysis.completeFunctionParens\\\": true,\\r\\n    \\\"git.autofetch\\\": true,\\r\\n    \\\"git.confirmSync\\\": false,\\r\\n    \\\"editor.fontSize\\\": 14,\\r\\n    \\\"editor.mouseWheelZoom\\\": true,\\r\\n    \\\"bracketPairColorizer.depreciation-notice\\\": false,\\r\\n    \\\"[html]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"esbenp.prettier-vscode\\\"\\r\\n    },\\r\\n    \\\"vscode-pets.petColor\\\": \\\"yellow\\\",\\r\\n    \\\"vscode-pets.petType\\\": \\\"dog\\\",\\r\\n    \\\"vscode-pets.theme\\\": \\\"beach\\\",\\r\\n    \\\"vscode-pets.position\\\": \\\"explorer\\\",\\r\\n    \\\"terminal.integrated.defaultProfile.windows\\\": \\\"PowerShell\\\",\\r\\n    \\\"terminal.integrated.fontFamily\\\": \\\"Hack Nerd Font Mono\\\",\\r\\n    \\\"terminal.integrated.fontSize\\\": 15,\\r\\n    \\\"workbench.colorTheme\\\": \\\"Andromeda Colorizer\\\",\\r\\n    \\\"workbench.iconTheme\\\": \\\"vscode-icons\\\",\\r\\n    \\\"editor.inlineSuggest.enabled\\\": true,\\r\\n    \\\"github.copilot.enable\\\": {\\r\\n        \\\"*\\\": true,\\r\\n        \\\"plaintext\\\": true,\\r\\n        \\\"markdown\\\": true,\\r\\n        \\\"scminput\\\": false,\\r\\n        \\\"yaml\\\": false\\r\\n    },\\r\\n    \\\"[python]\\\": {\\r\\n        \\\"editor.formatOnType\\\": true,\\r\\n        \\\"editor.defaultFormatter\\\": \\\"ms-python.python\\\"\\r\\n    },\\r\\n    \\\"vscode-pets.petSize\\\": \\\"small\\\",\\r\\n    \\\"[javascript]\\\": {\\r\\n        \\\"editor.defaultFormatter\\\": \\\"vscode.typescript-language-features\\\"\\r\\n    },\\r\\n    \\\"prettier.tabWidth\\\": 4,\\r\\n    \\\"editor.linkedEditing\\\": true,\\r\\n    \\\"workbench.activityBar.location\\\": \\\"top\\\",\\r\\n    \\\"workbench.editor.showTabs\\\": \\\"multiple\\\",\\r\\n    \\\"window.zoomLevel\\\": 2,\\r\\n    \\\"terminal.external.windowsExec\\\": \\\"C:\\\\\\\\Users\\\\\\\\johan\\\\\\\\AppData\\\\\\\\Local\\\\\\\\Microsoft\\\\\\\\WindowsApps\\\\\\\\wt.exe\\\",\\r\\n    \\\"editor.accessibilitySupport\\\": \\\"off\\\"\\r\\n}\\r\\n\"}","snippets":"{\"snippets\":{\"html.json\":\"{\\n\\t// Place your snippets for html here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"if from Python | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"if\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"{% if ${1:condition} %}\\\",\\n\\t\\t\\t\\\"\\\\t${2}\\\",\\n\\t\\t\\t\\\"{% endif %}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'if' and 'endif' for Python code in HTML\\\"\\n\\t},\\n\\t\\\"for from Python | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"for\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"{% for ${1:i} in ${2:where} %}\\\",\\n\\t\\t\\t\\\"\\\\t${3}\\\",\\n\\t\\t\\t\\\"{% endfor %}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'for' and 'endfor' for Python code in HTML\\\"\\n\\t},\\n}\",\"javascript.json\":\"{\\n\\t// Place your snippets for javascript here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\t\\\"const arrow function (req, res)\\\": {\\n\\t\\t\\\"prefix\\\": \\\"const arrow\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"const $1 = (${2:req}, ${3:res}) =>  {\\\",\\n\\t\\t\\t\\\"\\\\t$4\\\",\\n\\t\\t\\t\\\"};\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"const function (req, res)\\\"\\n\\t},\\n\\t\\\"Print to console with $variable\\\": {\\n\\t\\t\\\"prefix\\\": \\\"$log$\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"console.log(`$1${$2}`);\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Log output to console with $variable\\\"\\n\\t},\\n\\t\\\"const {  } = props;\\\": {\\n\\t\\t\\\"prefix\\\": \\\"const props\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"const { $1 } = props;\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"object destructury of props\\\"\\n\\t},\\n\\t\\\"const {  } = ${};\\\": {\\n\\t\\t\\\"prefix\\\": \\\"const object destructury\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"const { $2 } = $1;\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"object destructury\\\"\\n\\t},\\n}\",\"python.json\":\"{\\n\\t// Place your snippets for python here. Each snippet is defined under a snippet name and has a prefix, body and \\n\\t// description. The prefix is what is used to trigger the snippet and the body will be expanded and inserted. Possible variables are:\\n\\t// $1, $2 for tab stops, $0 for the final cursor position, and ${1:label}, ${2:another} for placeholders. Placeholders with the \\n\\t// same ids are connected.\\n\\t// Example:\\n\\t// \\\"Print to console\\\": {\\n\\t// \\t\\\"prefix\\\": \\\"log\\\",\\n\\t// \\t\\\"body\\\": [\\n\\t// \\t\\t\\\"console.log('$1');\\\",\\n\\t// \\t\\t\\\"$2\\\"\\n\\t// \\t],\\n\\t// \\t\\\"description\\\": \\\"Log output to console\\\"\\n\\t// }\\n\\n\\t// Function snippets\\n\\t\\\"if __name__ == '__main__'\\\": {\\n\\t\\t\\\"prefix\\\": \\\"if __name__ == '__main__'\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def main():\\\",\\n\\t\\t\\t\\\"\\\\t${1:pass}\\\",\\n\\t\\t\\t\\\"\\\",\\n\\t\\t\\t\\\"if __name__ == '__main__':\\\",\\n\\t\\t\\t\\\"\\\\tmain()\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"__main__ function\\\"\\n\\t},\\n\\t\\\"def function\\\": {\\n\\t\\t\\\"prefix\\\": \\\"def\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def ${1:function}(${2:}) -> ${3:None}:\\\",\\n\\t\\t\\t\\\"\\\\t${4:raise NotImplementedError}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate template function\\\"\\n\\t},\\n\\t\\\"def __init__\\\": {\\n\\t\\t\\\"prefix\\\": \\\"def __init__\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"def __init__(self, ${1:}) -> None:\\\",\\n\\t\\t\\t\\\"\\\\t${2:raise NotImplementedError}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate Constructor method.\\\"\\n\\t},\\n\\n\\t// Class snippets\\n\\t\\\"class NewClass\\\": {\\n\\t\\t\\\"prefix\\\": \\\"class NewClass\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"class ${1:NewClass}:\\\",\\n\\t\\t\\t\\\"\\\\tdef __init__(self, ${2:}) -> None:\\\",\\n\\t\\t\\t\\\"\\\\t\\\\t${3:raise NotImplementedError}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate New Class with Constructor method.s\\\"\\n\\t},\\n\\n\\t// Try Catch and Exceptions snippets\\n\\t\\\"try, except ValueError\\\": {\\n\\t\\t\\\"prefix\\\": \\\"try & except ValueError\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"try:\\\",\\n\\t\\t\\t\\\"\\\\tpass\\\",\\n\\t\\t\\t\\\"except ${1:ValueError}:\\\",\\n\\t\\t\\t\\\"\\\\tpass\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate try except\\\"\\n\\t},\\n\\t\\\"try, except as Exception\\\": {\\n\\t\\t\\\"prefix\\\": \\\"try & except as Exception\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"try:\\\",\\n\\t\\t\\t\\\"\\\\tpass\\\",\\n\\t\\t\\t\\\"except Exception as e:\\\",\\n\\t\\t\\t\\\"\\\\tprint(${1:e})\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"Generate try except Exception\\\"\\n\\t},\\n\\n\\t// \\n\\t// Django snippets\\n\\t// \\n\\t\\\"max_length Django | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"max_length\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"max_length=${1:100}${2}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'max_length' parameter for models in Django\\\"\\n\\t},\\n\\t\\\"unique Django | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"unique\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"unique=${1:True}${2}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'unique' parameter for models in Django\\\"\\n\\t},\\n\\t\\\"blank Django | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"blank\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"blank=${1:False}${2}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'blank' parameter for models in Django\\\"\\n\\t},\\n\\t\\\"upload_to Django | johanfire\\\": {\\n\\t\\t\\\"prefix\\\": \\\"upload_to\\\",\\n\\t\\t\\\"body\\\": [\\n\\t\\t\\t\\\"upload_to='${1}'${2}\\\",\\n\\t\\t],\\n\\t\\t\\\"description\\\": \\\"'upload_to' parameter for models in Django\\\"\\n\\t},\\n}\"}}","extensions":"[{\"identifier\":{\"id\":\"alefragnani.project-manager\",\"uuid\":\"1b747f06-3789-4ebd-ac99-f1fe430c3347\"},\"displayName\":\"Project Manager\"},{\"identifier\":{\"id\":\"amandeepmittal.pug\",\"uuid\":\"93d76817-75fd-47d0-bec0-d5f7ca64caeb\"},\"displayName\":\"pug\"},{\"identifier\":{\"id\":\"bradlc.vscode-tailwindcss\",\"uuid\":\"4db62a7c-7d70-419c-96d2-6c3a4dc77ea5\"},\"displayName\":\"Tailwind CSS IntelliSense\"},{\"identifier\":{\"id\":\"codezombiech.gitignore\",\"uuid\":\"3e891cf9-53cb-49a3-8d01-8f0b1f0afb29\"},\"displayName\":\"gitignore\"},{\"identifier\":{\"id\":\"donjayamanne.git-extension-pack\",\"uuid\":\"d23dc2c3-abed-47d8-9b22-7dd31c1f0ed9\"},\"displayName\":\"Git Extension Pack\"},{\"identifier\":{\"id\":\"donjayamanne.githistory\",\"uuid\":\"5960f38e-0